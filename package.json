{
  "name": "brighthome",
  "version": "1.0.0",
  "description": "BrightHome - Premium Lighting & Home Decor Store",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "agent:research":   "npx ts-node agents/agent1-research.ts",
    "agent:images":     "npx ts-node agents/agent2-images.ts",
    "agent:content":    "npx ts-node agents/agent3-content.ts",
    "agent:publish":    "npx ts-node agents/agent4-publishing.ts",
    "agent:social":     "npx ts-node agents/agent5-social.ts",
    "agent:ads":        "npx ts-node agents/agent6-ads.ts",
    "agent:analytics":  "npx ts-node agents/agent7-analytics.ts",
    "agent:report":     "npx ts-node agents/agent8-reporting.ts",
    "agent:optimize":   "npx ts-node agents/agent9-optimization.ts",
    "agent:frontend":   "npx ts-node agents/agent10-frontend.ts",
    "agent:all":        "npm run agent:research && npm run agent:images && npm run agent:content && npm run agent:publish"
  },
  "dependencies": {
    "next":                  "14.2.5",
    "react":                 "^18",
    "react-dom":             "^18",
    "typescript":            "^5",
    "framer-motion":         "^11.3.0",
    "axios":                 "^1.7.2",
    "mongoose":              "^8.5.1",
    "cloudinary":            "^2.3.1",
    "@sendgrid/mail":        "^8.1.3",
    "@google/generative-ai": "^0.16.0",
    "sharp":                 "^0.33.4",
    "dotenv":                "^16.4.5",
    "googleapis":            "^140.0.1",
    "google-auth-library":   "^9.13.0",
    "uuid":                  "^10.0.0",
    "date-fns":              "^3.6.0",
    "nodemailer":            "^6.9.14",
    "ts-node":               "^10.9.2"
  },
  "devDependencies": {
    "@types/node":          "^20",
    "@types/react":         "^18",
    "@types/react-dom":     "^18",
    "autoprefixer":         "^10.4.19",
    "postcss":              "^8.4.40",
    "tailwindcss":          "^3.4.7",
    "eslint":               "^8",
    "eslint-config-next":   "14.2.5"
  }
}
